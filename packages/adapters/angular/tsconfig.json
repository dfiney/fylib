{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@fylib/core": ["../../core/dist/index"],
      "@fylib/logger": ["../../logger/dist/index"],
      "@fylib/theme": ["../../theme/dist/index"],
      "@fylib/animation": ["../../animation/dist/index"],
      "@fylib/catalog": ["../../catalog/dist/index"],
      "@fylib/config": ["../../config/dist/index"],
      "@fylib/crypto": ["../../crypto/dist/index"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "skipTemplateCodegen": true,
    "strictMetadataEmit": true,
    "enableResourceInlining": true
  },
  "include": ["src"]
}
