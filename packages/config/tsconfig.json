{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@fylib/core": ["../core/dist/index"],
      "@fylib/logger": ["../logger/dist/index"],
      "@fylib/animation": ["../animation/dist/index"],
      "@fylib/crypto": ["../crypto/dist/index"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
